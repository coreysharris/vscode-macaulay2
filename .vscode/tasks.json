// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": {
				"owner": "esbuild",
				"fileLocation": [
					"relative",
					"${workspaceFolder}"
				],
				"pattern": {
					"regexp": "^\\s*(error|warning):\\s+(.*)$",
					"severity": 1,
					"message": 2
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^> .* watch$",
					"endsPattern": "^Watching for changes\\.\\.\\.$"
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}
